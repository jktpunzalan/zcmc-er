# HIE Integration Configuration
# Copy these settings to your .env file

# Enable/Disable HIE Integration
HIE_ENABLED=true

# Patient Registry Configuration
PATIENT_REGISTRY_URL=http://localhost:8080/api/v1
PATIENT_REGISTRY_TOKEN=2|your-pos-token-here
PATIENT_REGISTRY_CORRELATION_PREFIX=ER-ZCMC
PATIENT_REGISTRY_TIMEOUT=30

# SHRR (Shared Health Record Repository) Configuration
SHRR_BASE_URL=http://localhost:8080/api/v1
SHRR_TOKEN=2|your-shrr-pos-token-here
SHRR_TIMEOUT=30

# HIE Queue Configuration
HIE_QUEUE_CONNECTION=database
HIE_QUEUE_NAME=hie

# HIE Logging
HIE_LOGGING_ENABLED=true
HIE_LOG_CHANNEL=hie
HIE_LOG_REQUESTS=true
HIE_LOG_RESPONSES=false
HIE_LOG_LEVEL=info
